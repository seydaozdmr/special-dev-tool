{
  "name": "json-formatter",
  "version": "1.0.0",
  "description": "A local JSON formatter desktop app for macOS",
  "productName": "JSON Formatter",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac dmg",
    "build:dir": "electron-builder --mac dir"
  },
  "keywords": ["json", "formatter", "electron", "developer-tools"],
  "author": "seydaozdemir07@gmail.com",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.devtools.json-formatter",
    "productName": "JSON Formatter",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ]
    },
    "dmg": {
      "title": "JSON Formatter",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "build/**/*"
    ]
  }
}
